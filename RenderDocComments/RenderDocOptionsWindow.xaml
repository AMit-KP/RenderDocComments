<Window
	x:Class="RenderDocComments.RenderDocOptionsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="RenderDocComments Options"
	Width="626"
	Background="#1E1E1E"
	FontFamily="Segoe UI"
	FontSize="13"
	Foreground="#D4D4D4"
	ResizeMode="NoResize"
	SizeToContent="Height"
	WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<!--  Section header style  -->
		<Style x:Key="SectionHeader" TargetType="TextBlock">
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="#9CDCFE" />
			<Setter Property="Margin" Value="0,14,0,4" />
		</Style>

		<!--  Label style  -->
		<Style x:Key="OptionLabel" TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="Margin" Value="0,0,8,0" />
		</Style>

		<!--  CheckBox style  -->
		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Margin" Value="0,3,0,3" />
		</Style>

		<!--  TextBox style  -->
		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="4,2" />
			<Setter Property="Margin" Value="0,2,0,2" />
		</Style>

		<!--  ComboBox style  -->
		<Style TargetType="ComboBox">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="4,2" />
			<Setter Property="Margin" Value="0,2,0,2" />
			<Setter Property="ItemContainerStyle">
				<Setter.Value>
					<Style TargetType="ComboBoxItem">
						<Setter Property="Background" Value="#2D2D2D" />
						<Setter Property="Foreground" Value="#D4D4D4" />
						<Setter Property="Padding" Value="6,3" />
						<Style.Triggers>
							<Trigger Property="IsHighlighted" Value="True">
								<Setter Property="Background" Value="#094771" />
								<Setter Property="Foreground" Value="#FFFFFF" />
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter Property="Background" Value="#0E639C" />
								<Setter Property="Foreground" Value="#FFFFFF" />
							</Trigger>
						</Style.Triggers>
					</Style>
				</Setter.Value>
			</Setter>
		</Style>

		<!--  Primary button  -->
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="#0E639C" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#1177BB" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#1177BB" />
				</Trigger>
			</Style.Triggers>
		</Style>

		<!--  Secondary button  -->
		<Style x:Key="SecondaryButton" TargetType="Button">
			<Setter Property="Background" Value="#3C3C3C" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>

		<!--  Premium badge  -->
		<Style x:Key="PremiumBadge" TargetType="Border">
			<Setter Property="Background" Value="#BE6EF0" />
			<Setter Property="CornerRadius" Value="3" />
			<Setter Property="Padding" Value="5,1" />
			<Setter Property="Margin" Value="6,0,0,0" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<!--  Colour swatch button  -->
		<Style x:Key="SwatchButton" TargetType="Button">
			<Setter Property="Width" Value="28" />
			<Setter Property="Height" Value="22" />
			<Setter Property="BorderBrush" Value="#888" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Padding" Value="2" />
		</Style>

		<!--  Disabled overlay  -->
		<Style x:Key="PremiumGroup" TargetType="StackPanel">
			<Style.Triggers>
				<DataTrigger Binding="{Binding PremiumUnlocked}" Value="False">
					<Setter Property="Opacity" Value="0.45" />
					<Setter Property="IsEnabled" Value="False" />
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="24,16,24,20">

			<!--  ══ Title ══════════════════════════════════════════════════════════  -->
			<TextBlock
				Margin="0,0,0,2"
				FontSize="18"
				FontWeight="Bold"
				Foreground="#BE6EF0"
				Text="Render Doc Comments" />
			<TextBlock
				Margin="0,0,0,10"
				FontSize="11"
				Foreground="#888"
				Text="Visual Studio Extension Settings" />

			<Separator Margin="0,4,0,4" Background="#444" />

			<!--  ══ Licence / Premium ══════════════════════════════════════════════════  -->
			<TextBlock Style="{StaticResource SectionHeader}" Text="Licence" />

			<StackPanel
				Width="576"
				Margin="0,4,0,8"
				HorizontalAlignment="Left"
				Orientation="Horizontal">
				<Border
					x:Name="PremiumStatusBadge"
					Margin="0,0,10,0"
					Padding="8,3"
					VerticalAlignment="Center"
					CornerRadius="4">
					<TextBlock
						x:Name="PremiumStatusText"
						FontSize="12"
						FontWeight="SemiBold" />
				</Border>
				<TextBox
					x:Name="LicenseKeyBox"
					Width="220"
					VerticalAlignment="Center"
					Text=""
					ToolTip="Enter your Premium licence key" />
				<Button
					x:Name="ActivateButton"
					VerticalAlignment="Center"
					Click="OnActivateClicked"
					Content="Activate"
					Style="{StaticResource PrimaryButton}" />
				<Button
					x:Name="DeactivateButton"
					VerticalAlignment="Center"
					Click="OnDeactivateClicked"
					Content="Deactivate"
					Style="{StaticResource SecondaryButton}" />
			</StackPanel>

			<TextBlock
				x:Name="LicenseMessageText"
				Margin="0,0,0,6"
				FontSize="11"
				Foreground="#F48771"
				Visibility="Collapsed" />

			<Separator Margin="0,4,0,4" Background="#444" />

			<!--  ══ FREE: Global render toggle ════════════════════════════════════  -->
			<TextBlock Style="{StaticResource SectionHeader}" Text="General (Free)" />

			<CheckBox
				x:Name="RenderEnabledCheck"
				Checked="OnSettingChanged"
				Content="Enable doc comment rendering"
				Unchecked="OnSettingChanged" />

			<Separator Margin="0,10,0,4" Background="#444" />

			<!--  ══ Premium section header ───────────────────────────────────────────  -->
			<StackPanel Orientation="Horizontal">
				<TextBlock
					Margin="0,14,6,4"
					Style="{StaticResource SectionHeader}"
					Text="Premium Features" />
				<Border
					Height="18"
					Margin="0,12,0,0"
					VerticalAlignment="Center"
					Style="{StaticResource PremiumBadge}">
					<TextBlock
						FontSize="10"
						FontWeight="Bold"
						Foreground="White"
						Text="Premium" />
				</Border>
			</StackPanel>

			<TextBlock
				Margin="0,0,0,10"
				FontSize="11"
				Foreground="#888"
				Text="The options below require a Premium licence. Without Premium they are shown but disabled, and the default free behaviour is used."
				TextWrapping="Wrap" />

			<!--  Premium options container — disabled when not unlocked  -->
			<StackPanel x:Name="PremiumOptionsPanel">

				<!--  4.1 Auto theme refresh  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Theme Auto-Refresh" />
				<CheckBox
					x:Name="AutoRefreshCheck"
					Checked="OnSettingChanged"
					Content="Auto-refresh colours when VS colour theme changes (no file reopen needed)"
					Unchecked="OnSettingChanged" />

				<!--  4.2 Glyph toggle  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Margin Glyph Toggle" />
				<StackPanel Margin="8,6,8,6">
					<RadioButton
						x:Name="CaretModeRadio"
						Margin="0,0,0,6"
						Checked="OnToggleModeChanged"
						Content="Caret-based (free) — moving caret into block shows raw XML"
						Foreground="#D4D4D4" />
					<RadioButton
						x:Name="GlyphModeRadio"
						Checked="OnToggleModeChanged"
						Content="Margin glyph button (Premium) — click the glyph to toggle per comment"
						Foreground="#D4D4D4" />
				</StackPanel>

				<!--  4.3 Font  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Rendered Font" />
				<StackPanel Margin="0,2,0,4" Orientation="Horizontal">
					<TextBlock Style="{StaticResource OptionLabel}" Text="Font family:" />
					<ComboBox
						x:Name="FontFamilyCombo"
						Width="220"
						Foreground="Black"
						SelectionChanged="OnFontFamilyChanged" />
					<TextBlock
						x:Name="FontPreviewText"
						Margin="12,0,0,0"
						VerticalAlignment="Center"
						Foreground="#BE6EF0"
						Text="AaBbCc 123" />
				</StackPanel>

				<!--  4.4 Border sides  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Accent Bar Sides" />
				<TextBlock
					Margin="0,0,0,4"
					FontSize="11"
					Foreground="#888"
					Text="Choose which sides display the gradient accent bar. Left is the default." />
				<StackPanel Margin="0,2,0,4" Orientation="Horizontal">
					<CheckBox
						x:Name="BorderLeftCheck"
						Margin="0,0,16,0"
						Checked="OnSettingChanged"
						Content="Left"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderTopCheck"
						Margin="0,0,16,0"
						Checked="OnSettingChanged"
						Content="Top"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderRightCheck"
						Margin="0,0,16,0"
						Checked="OnSettingChanged"
						Content="Right"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderBottomCheck"
						Checked="OnSettingChanged"
						Content="Bottom"
						Unchecked="OnSettingChanged" />
				</StackPanel>

				<!--  4.5 Colours  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Colours" />
				<TextBlock
					Margin="0,0,0,6"
					FontSize="11"
					Foreground="#888"
					Text="Click a swatch to open the colour picker." />

				<Grid Margin="0,0,0,6">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<!--  Row 0  -->
					<StackPanel
						Grid.Row="0"
						Grid.Column="0"
						Margin="0,3"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchCodeFg"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="CodeFg" />
						<TextBlock
							Margin="6,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Inline code / quoted" />
					</StackPanel>
					<StackPanel
						Grid.Row="0"
						Grid.Column="1"
						Margin="0,3"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchSummaryFg"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="SummaryFg" />
						<TextBlock
							Margin="6,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Summary text" />
					</StackPanel>

					<!--  Row 1  -->
					<StackPanel
						Grid.Row="1"
						Grid.Column="0"
						Margin="0,3"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchParamName"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="ParamName" />
						<TextBlock
							Margin="6,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Parameter names" />
					</StackPanel>
					<StackPanel
						Grid.Row="1"
						Grid.Column="1"
						Margin="0,3"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchLink"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="Link" />
						<TextBlock
							Margin="6,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Links / crefs" />
					</StackPanel>

					<!--  Row 2  -->
					<StackPanel
						Grid.Row="2"
						Grid.Column="0"
						Margin="0,3"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchSectionLabel"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="SectionLabel" />
						<TextBlock
							Margin="6,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Section headings" />
					</StackPanel>
				</Grid>

				<!--  Gradient colours  -->
				<TextBlock
					Margin="0,8,0,4"
					FontSize="12"
					FontWeight="SemiBold"
					Foreground="#D4D4D4"
					Text="Gradient bar colours:" />

				<!--  Preset buttons  -->
				<StackPanel Margin="0,0,0,6" Orientation="Horizontal">
					<TextBlock Style="{StaticResource OptionLabel}" Text="Presets:" />
					<Button
						Padding="8,4"
						Click="OnGradientPresetClicked"
						Content="Purple (default)"
						Style="{StaticResource SecondaryButton}"
						Tag="Purple" />
					<Button
						Padding="8,4"
						Click="OnGradientPresetClicked"
						Content="Ocean Blue"
						Style="{StaticResource SecondaryButton}"
						Tag="Ocean" />
					<Button
						Padding="8,4"
						Click="OnGradientPresetClicked"
						Content="Sunset"
						Style="{StaticResource SecondaryButton}"
						Tag="Sunset" />
					<Button
						Padding="8,4"
						Click="OnGradientPresetClicked"
						Content="Forest"
						Style="{StaticResource SecondaryButton}"
						Tag="Forest" />
					<Button
						Padding="8,4"
						Click="OnGradientPresetClicked"
						Content="Rose Gold"
						Style="{StaticResource SecondaryButton}"
						Tag="RoseGold" />
				</StackPanel>

				<StackPanel Margin="0,2,0,8" Orientation="Horizontal">
					<Button
						x:Name="SwatchGrad0"
						Width="36"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad0" />
					<TextBlock
						Margin="4,0,16,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 1" />
					<Button
						x:Name="SwatchGrad1"
						Width="36"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad1" />
					<TextBlock
						Margin="4,0,16,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 2" />
					<Button
						x:Name="SwatchGrad2"
						Width="36"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad2" />
					<TextBlock
						Margin="4,0,16,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 3" />
					<!--  Live preview bar  -->
					<Border
						x:Name="GradientPreviewBar"
						Width="237"
						Height="22"
						Margin="12,0,0,0"
						CornerRadius="3" />
				</StackPanel>

			</StackPanel>
			<!--  /PremiumOptionsPanel  -->

			<Separator Margin="0,10,0,10" Background="#444" />

			<!--  ── Footer buttons ────────────────────────────────────────────────  -->
			<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
				<Button
					Click="OnResetClicked"
					Content="Reset to Defaults"
					Style="{StaticResource SecondaryButton}" />
				<Button
					Click="OnSaveClicked"
					Content="Save"
					Style="{StaticResource PrimaryButton}" />
				<Button
					Click="OnCloseClicked"
					Content="Close"
					Style="{StaticResource SecondaryButton}" />
			</StackPanel>

		</StackPanel>
	</ScrollViewer>
</Window>
