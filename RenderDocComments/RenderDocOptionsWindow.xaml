<Window
	x:Class="RenderDocComments.RenderDocOptionsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="RenderDocComments Options"
	Width="600"
	Background="#1E1E1E"
	FontFamily="Segoe UI"
	FontSize="13"
	Foreground="#D4D4D4"
	ResizeMode="NoResize"
	SizeToContent="Height"
	WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<Style x:Key="SectionHeader" TargetType="TextBlock">
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="#9CDCFE" />
			<Setter Property="Margin" Value="0,10,0,3" />
		</Style>
		<Style x:Key="OptionLabel" TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="Margin" Value="0,0,8,0" />
		</Style>
		<Style TargetType="CheckBox">
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Margin" Value="0,2,0,2" />
		</Style>
		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="4,2" />
			<Setter Property="Margin" Value="0,2,0,2" />
		</Style>
		<Style TargetType="ComboBox">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="4,2" />
			<Setter Property="Margin" Value="0,2,0,2" />
			<Setter Property="ItemContainerStyle">
				<Setter.Value>
					<Style TargetType="ComboBoxItem">
						<Setter Property="Background" Value="#2D2D2D" />
						<Setter Property="Foreground" Value="#D4D4D4" />
						<Setter Property="Padding" Value="6,3" />
						<Style.Triggers>
							<Trigger Property="IsHighlighted" Value="True">
								<Setter Property="Background" Value="#094771" />
								<Setter Property="Foreground" Value="#FFFFFF" />
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter Property="Background" Value="#0E639C" />
								<Setter Property="Foreground" Value="#FFFFFF" />
							</Trigger>
						</Style.Triggers>
					</Style>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="#0E639C" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#1177BB" />
			<Setter Property="Padding" Value="10,4" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#1177BB" />
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="SecondaryButton" TargetType="Button">
			<Setter Property="Background" Value="#3C3C3C" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="10,4" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>
		<Style x:Key="PremiumBadge" TargetType="Border">
			<Setter Property="Background" Value="#BE6EF0" />
			<Setter Property="CornerRadius" Value="3" />
			<Setter Property="Padding" Value="5,1" />
			<Setter Property="Margin" Value="6,0,0,0" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style x:Key="SwatchButton" TargetType="Button">
			<Setter Property="Width" Value="26" />
			<Setter Property="Height" Value="20" />
			<Setter Property="BorderBrush" Value="#888" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Padding" Value="2" />
		</Style>
	</Window.Resources>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="20,12,20,16">

			<!--  ══ Title  -->
			<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
				<TextBlock
					FontSize="16"
					FontWeight="Bold"
					Foreground="#BE6EF0"
					Text="Render Doc Comments" />
				<TextBlock
					Margin="10,0,0,0"
					VerticalAlignment="Center"
					FontSize="11"
					Foreground="#888"
					Text="Visual Studio Extension" />
			</StackPanel>

			<Separator Margin="0,8,0,0" Background="#444" />

			<!--  ══ Licence  -->
			<TextBlock Style="{StaticResource SectionHeader}" Text="Licence" />

			<StackPanel
				Margin="0,2,0,6"
				VerticalAlignment="Center"
				Orientation="Horizontal">
				<Border
					x:Name="PremiumStatusBadge"
					Margin="0,0,10,0"
					Padding="8,3"
					VerticalAlignment="Center"
					CornerRadius="4">
					<TextBlock
						x:Name="PremiumStatusText"
						FontSize="12"
						FontWeight="SemiBold" />
				</Border>

				<!--  Free: open the purchase/activation window  -->
				<Button
					x:Name="GetPremiumButton"
					Click="OnGetPremiumClicked"
					Content="Get Premium…"
					Style="{StaticResource PrimaryButton}"
					Visibility="Collapsed" />

				<!--  Premium: deactivate this machine  -->
				<Button
					x:Name="DeactivateButton"
					Click="OnDeactivateClicked"
					Content="Deactivate this machine"
					Style="{StaticResource SecondaryButton}"
					Visibility="Collapsed" />
			</StackPanel>

			<TextBlock
				x:Name="LicenseMessageText"
				Margin="0,0,0,4"
				FontSize="11"
				Foreground="#F48771"
				TextWrapping="Wrap"
				Visibility="Collapsed" />

			<Separator Margin="0,4,0,0" Background="#444" />

			<!--  ══ FREE: Global render toggle  -->
			<TextBlock Style="{StaticResource SectionHeader}" Text="General (Free)" />

			<CheckBox
				x:Name="RenderEnabledCheck"
				Checked="OnSettingChanged"
				Content="Enable doc comment rendering"
				Unchecked="OnSettingChanged" />

			<!--  ══ Premium section  -->
			<StackPanel Orientation="Horizontal">
				<TextBlock
					Margin="0,10,6,3"
					Style="{StaticResource SectionHeader}"
					Text="Premium Features" />
				<Border
					Height="16"
					Margin="0,8,0,0"
					VerticalAlignment="Center"
					Style="{StaticResource PremiumBadge}">
					<TextBlock
						FontSize="9"
						FontWeight="Bold"
						Foreground="White"
						Text="PREMIUM" />
				</Border>
			</StackPanel>

			<TextBlock
				Margin="0,0,0,6"
				FontSize="11"
				Foreground="#888"
				Text="Requires a Premium licence. Options are shown but disabled without one."
				TextWrapping="Wrap" />

			<StackPanel x:Name="PremiumOptionsPanel" Margin="0,0,0,6">

				<!--  Glyph toggle  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Margin Glyph Toggle" />
				<StackPanel Margin="6,4,6,6">
					<RadioButton
						x:Name="CaretModeRadio"
						Margin="0,0,0,4"
						Checked="OnToggleModeChanged"
						Content="Caret-based (free) — caret in block shows raw XML"
						Foreground="#D4D4D4" />
					<RadioButton
						x:Name="GlyphModeRadio"
						Checked="OnToggleModeChanged"
						Content="Margin glyph button (Premium) — click to toggle per comment"
						Foreground="#D4D4D4" />
				</StackPanel>

				<!--  Auto theme refresh  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Theme Auto-Refresh" />
				<CheckBox
					x:Name="AutoRefreshCheck"
					Checked="OnSettingChanged"
					Content="Auto-refresh colours when VS colour theme changes"
					Unchecked="OnSettingChanged" />

				<!--  Fixed width  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Comment Width" />
				<CheckBox
					x:Name="UseFixedWidthCheck"
					Checked="OnFixedWidthChanged"
					Content="Use fixed width"
					Unchecked="OnFixedWidthChanged" />
				<StackPanel Margin="20,2,0,6" Orientation="Horizontal">
					<TextBlock Style="{StaticResource OptionLabel}" Text="Fixed width (px):" />
					<TextBox
						x:Name="FixedWidthText"
						Width="70"
						TextAlignment="Left"
						TextChanged="OnFixedWidthTextChanged" />
				</StackPanel>

				<!--  Font  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Rendered Font" />
				<StackPanel Margin="0,2,0,2" Orientation="Horizontal">
					<TextBlock Style="{StaticResource OptionLabel}" Text="Font family:" />
					<ComboBox
						x:Name="FontFamilyCombo"
						Width="200"
						Foreground="Black"
						SelectionChanged="OnFontFamilyChanged" />
					<TextBlock
						x:Name="FontPreviewText"
						Margin="10,0,0,0"
						VerticalAlignment="Center"
						Foreground="#BE6EF0"
						Text="AaBbCc 123" />
				</StackPanel>

				<!--  Border sides  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Accent Bar Sides" />
				<StackPanel Margin="0,2,0,2" Orientation="Horizontal">
					<CheckBox
						x:Name="BorderLeftCheck"
						Margin="0,0,14,0"
						Checked="OnSettingChanged"
						Content="Left"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderTopCheck"
						Margin="0,0,14,0"
						Checked="OnSettingChanged"
						Content="Top"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderRightCheck"
						Margin="0,0,14,0"
						Checked="OnSettingChanged"
						Content="Right"
						Unchecked="OnSettingChanged" />
					<CheckBox
						x:Name="BorderBottomCheck"
						Checked="OnSettingChanged"
						Content="Bottom"
						Unchecked="OnSettingChanged" />
				</StackPanel>

				<!--  Colours  -->
				<TextBlock Style="{StaticResource SectionHeader}" Text="Colours" />
				<TextBlock
					Margin="0,0,0,4"
					FontSize="11"
					Foreground="#888"
					Text="Click a swatch to open the colour picker." />

				<Grid Margin="0,0,0,4">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>

					<StackPanel
						Grid.Row="0"
						Grid.Column="0"
						Margin="0,2"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchCodeFg"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="CodeFg" />
						<TextBlock
							Margin="5,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Inline code / quoted" />
					</StackPanel>
					<StackPanel
						Grid.Row="0"
						Grid.Column="1"
						Margin="0,2"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchSummaryFg"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="SummaryFg" />
						<TextBlock
							Margin="5,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Summary text" />
					</StackPanel>
					<StackPanel
						Grid.Row="1"
						Grid.Column="0"
						Margin="0,2"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchParamName"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="ParamName" />
						<TextBlock
							Margin="5,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Parameter names" />
					</StackPanel>
					<StackPanel
						Grid.Row="1"
						Grid.Column="1"
						Margin="0,2"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchLink"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="Link" />
						<TextBlock
							Margin="5,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Links / crefs" />
					</StackPanel>
					<StackPanel
						Grid.Row="2"
						Grid.Column="0"
						Margin="0,2"
						Orientation="Horizontal">
						<Button
							x:Name="SwatchSectionLabel"
							Click="OnSwatchClicked"
							Style="{StaticResource SwatchButton}"
							Tag="SectionLabel" />
						<TextBlock
							Margin="5,0,0,0"
							Style="{StaticResource OptionLabel}"
							Text="Section headings" />
					</StackPanel>
				</Grid>
				<!--  Gradient  -->
				<TextBlock
					Margin="0,6,0,3"
					FontSize="11"
					FontWeight="SemiBold"
					Foreground="#D4D4D4"
					Text="Gradient bar:" />

				<StackPanel Margin="0,0,0,4" Orientation="Horizontal">
					<TextBlock Style="{StaticResource OptionLabel}" Text="Presets:" />
					<Button
						Padding="6,3"
						Click="OnGradientPresetClicked"
						Content="Purple"
						Style="{StaticResource SecondaryButton}"
						Tag="Purple" />
					<Button
						Padding="6,3"
						Click="OnGradientPresetClicked"
						Content="Ocean"
						Style="{StaticResource SecondaryButton}"
						Tag="Ocean" />
					<Button
						Padding="6,3"
						Click="OnGradientPresetClicked"
						Content="Sunset"
						Style="{StaticResource SecondaryButton}"
						Tag="Sunset" />
					<Button
						Padding="6,3"
						Click="OnGradientPresetClicked"
						Content="Forest"
						Style="{StaticResource SecondaryButton}"
						Tag="Forest" />
					<Button
						Padding="6,3"
						Click="OnGradientPresetClicked"
						Content="Rose Gold"
						Style="{StaticResource SecondaryButton}"
						Tag="RoseGold" />
				</StackPanel>

				<StackPanel Margin="0,2,0,6" Orientation="Horizontal">
					<Button
						x:Name="SwatchGrad0"
						Width="32"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad0" />
					<TextBlock
						Margin="3,0,12,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 1" />
					<Button
						x:Name="SwatchGrad1"
						Width="32"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad1" />
					<TextBlock
						Margin="3,0,12,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 2" />
					<Button
						x:Name="SwatchGrad2"
						Width="32"
						Click="OnSwatchClicked"
						Style="{StaticResource SwatchButton}"
						Tag="Grad2" />
					<TextBlock
						Margin="3,0,12,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="#888"
						Text="Stop 3" />
					<Border
						x:Name="GradientPreviewBar"
						Width="220"
						Height="20"
						Margin="8,0,0,0"
						CornerRadius="3" />
				</StackPanel>

			</StackPanel>
			<!--  /PremiumOptionsPanel  -->

			<!--  ── Footer  -->
			<Grid Margin="-4,6,0,0">
				<StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
					<Button
						Click="RatingButton_Click"
						Content="Please, leave a review"
						Foreground="#BE6EF0"
						Style="{StaticResource SecondaryButton}" />

				</StackPanel>
				<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
					<Button
						Click="OnResetClicked"
						Content="Reset to Defaults"
						Style="{StaticResource SecondaryButton}" />
					<Button
						Click="OnSaveClicked"
						Content="Save"
						Style="{StaticResource PrimaryButton}" />
					<Button
						Click="OnCloseClicked"
						Content="Close"
						Style="{StaticResource SecondaryButton}" />
				</StackPanel>
			</Grid>

		</StackPanel>
	</ScrollViewer>
</Window>
