<Window
	x:Class="RenderDocComments.PurchaseActivationWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Get Premium — Render Doc Comments"
	Width="500"
	Height="499"
	Background="#1E1E1E"
	FontFamily="Segoe UI"
	FontSize="13"
	Foreground="#D4D4D4"
	ResizeMode="NoResize"
	SizeToContent="Height"
	WindowStartupLocation="CenterOwner">

	<Window.Resources>
		<Style x:Key="SectionHeader" TargetType="TextBlock">
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="#9CDCFE" />
			<Setter Property="Margin" Value="0,10,0,3" />
		</Style>
		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#2D2D2D" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="6,4" />
			<Setter Property="Margin" Value="0,3,0,3" />
		</Style>
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="#0E639C" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#1177BB" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#1177BB" />
				</Trigger>
				<Trigger Property="IsEnabled" Value="False">
					<Setter Property="Background" Value="#444" />
					<Setter Property="Foreground" Value="#888" />
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="BuyButton" TargetType="Button">
			<Setter Property="Background" Value="#BE6EF0" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderBrush" Value="#9B44D0" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Padding" Value="18,7" />
			<Setter Property="Margin" Value="0,4,0,4" />
			<Setter Property="Cursor" Value="Hand" />
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#9B44D0" />
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="SecondaryButton" TargetType="Button">
			<Setter Property="Background" Value="#3C3C3C" />
			<Setter Property="Foreground" Value="#D4D4D4" />
			<Setter Property="BorderBrush" Value="#555" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="Margin" Value="4,0" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>
	</Window.Resources>

	<StackPanel Margin="24,16,22,9">

		<!--  Title  -->
		<TextBlock
			FontSize="17"
			FontWeight="Bold"
			Foreground="#BE6EF0"
			Text="🔓 Unlock Premium" />
		<TextBlock
			Margin="0,2,0,10"
			FontSize="11"
			Foreground="#888"
			Text="One-time purchase · Lifetime licence · 2 machines included" />

		<Separator Margin="0,0,0,0" Background="#444" />

		<!--  Feature list  -->
		<TextBlock Style="{StaticResource SectionHeader}" Text="What you get" />
		<StackPanel Margin="2,2,0,6">
			<TextBlock Margin="0,2" Text="✔  No Suscription — one-time purchase and activate on 2 machines" />
			<TextBlock Margin="0,2" Text="✔  Theme auto-refresh — colours update instantly on VS theme change" />
			<TextBlock Margin="0,2" Text="✔  Margin glyph button — toggle any comment with a single click" />
			<TextBlock Margin="0,2" Text="✔  Custom font family for the rendered view" />
			<TextBlock Margin="0,2" Text="✔  Accent bar sides — left / top / right / bottom" />
			<TextBlock Margin="0,2" Text="✔  Full colour customisation + gradient presets" />
		</StackPanel>

		<!--  Buy button  -->
		<Button
			x:Name="BuyNowButton"
			HorizontalAlignment="Left"
			Click="OnBuyNowClicked"
			Content="Buy Premium — Open Checkout ↗"
			Style="{StaticResource BuyButton}" />

		<TextBlock
			Height="20"
			Margin="0,6,0,0"
			FontSize="11"
			FontWeight="Bold"
			Foreground="WhiteSmoke"
			Text="DO NOT CLOSE THIS WINDOW UNTIL PAYMENT IS DONE."
			TextWrapping="Wrap" />

		<TextBlock
			Margin="0,0,0,6"
			FontSize="11"
			Foreground="WhiteSmoke"
			Text="After purchase, your licence key pre-filled here."
			TextWrapping="Wrap" />

		<TextBlock
			Margin="0,0,0,6"
			FontSize="11"
			Foreground="WhiteSmoke"
			Text="if closed, you can still activate your licence by pasting the key from your emails from DODO Payments. (Make sure to provide correct email address)."
			TextWrapping="Wrap" />

		<Separator Margin="0,2,0,2" Background="#444" />

		<!--  Activation form  -->
		<TextBlock Style="{StaticResource SectionHeader}" Text="Activate your licence" />

		<TextBlock
			Margin="0,0,0,4"
			FontSize="11"
			Foreground="#888"
			Text="If you already have a Licence key enter here:" />
		<Grid>
			<TextBox
				x:Name="KeyBox"
				Margin="0,3,0,3"
				FontFamily="Consolas"
				ToolTip="Your licence key — paste it here or complete the checkout above" />

			<Button
				x:Name="CopyBtn"
				Width="20"
				Height="20"
				Margin="0,0,6,0"
				Padding="0"
				HorizontalAlignment="Right"
				VerticalAlignment="Center"
				Background="Transparent"
				BorderThickness="0"
				Click="OnCopyClicked"
				Cursor="Hand"
				ToolTip="Copy the licence key to clipboard">
				<Canvas Width="16" Height="12">
					<!--  Back square (top-right)  -->
					<Rectangle
						Canvas.Top="0"
						Width="10"
						Height="10"
						HorizontalAlignment="Left"
						VerticalAlignment="Center"
						Fill="Transparent"
						RadiusX="1.5"
						RadiusY="1.5"
						Stroke="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
						StrokeThickness="1.5" />
					<!--  Front square (bottom-left)  -->
					<Rectangle
						Canvas.Left="3"
						Canvas.Top="3"
						Width="10"
						Height="10"
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						Fill="Transparent"
						RadiusX="1.5"
						RadiusY="1.5"
						Stroke="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
						StrokeThickness="1.5" />
				</Canvas>
			</Button>
		</Grid>

		<!--  Status message  -->
		<TextBlock
			x:Name="StatusText"
			Margin="0,4,0,4"
			FontSize="11"
			TextWrapping="Wrap"
			Visibility="Collapsed" />

		<!--  Buttons  -->
		<StackPanel
			Margin="0,6,0,0"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button
				x:Name="ActivateBtn"
				Click="OnActivateClicked"
				Content="Activate"
				Style="{StaticResource PrimaryButton}" />
			<Button
				Width="58"
				Click="OnCloseClicked"
				Content="Close"
				Style="{StaticResource SecondaryButton}" />
		</StackPanel>

	</StackPanel>
</Window>
